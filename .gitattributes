# Normalize line endings; let git decide text vs binary by default
* text=auto

# Source files always checked out with LF
*.c    text eol=lf
*.h    text eol=lf
*.cpp  text eol=lf
*.qml  text eol=lf
*.qrc  text eol=lf
*.jsx  text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.txt  text eol=lf
*.in   text eol=lf

# Binary assets
*.png  binary
*.gif  binary
*.jpg  binary
*.mp4  binary
